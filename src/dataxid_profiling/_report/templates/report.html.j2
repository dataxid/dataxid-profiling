<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if icon_b64 %}<link rel="icon" type="image/png" href="data:image/png;base64,{{ icon_b64 }}">{% endif %}
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              teal: '#0d3b3b',
              'teal-light': '#1a4a4a',
              coral: '#e8845c',
              'coral-light': '#f0956a',
              peach: '#f4a683',
              purple: '#b06aed',
              'purple-light': '#c77dff',
            }
          }
        }
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/echarts-wordcloud@2.2.0/dist/echarts-wordcloud.min.js"></script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .tab-btn { transition: all 0.2s ease; }
    .tab-btn.active, .tab-btn.active:hover { background: #0d3b3b; color: white; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .card { transition: box-shadow 0.2s ease; }
    .card:hover { box-shadow: 0 4px 12px rgba(13, 59, 59, 0.08); }
    .stat-row:nth-child(even) { background: #f8fafa; }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">

  {# ── Header ── #}
  <header class="bg-[#e8efed] border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-5">
        {% if logo_b64 %}
        <a href="https://dataxid.com?utm_source=profiling-report&amp;utm_medium=html" target="_blank" rel="noopener"><img src="data:image/png;base64,{{ logo_b64 }}" alt="DataXID" class="h-10" /></a>
        {% endif %}
        <div class="w-px h-10 bg-brand-teal/20"></div>
        <div>
          <h1 class="text-xl font-bold text-brand-teal">{{ title }}</h1>
          <p class="text-sm text-gray-500 mt-0.5">v{{ version }} &middot; {{ generated_at }}</p>
        </div>
      </div>
      <div class="flex items-center gap-5">
        <div class="text-center">
          <div class="text-2xl font-bold text-brand-teal">{{ overview.n_rows | format_number }}</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Rows</div>
        </div>
        <div class="w-px h-8 bg-brand-teal/15"></div>
        <div class="text-center">
          <div class="text-2xl font-bold text-brand-teal">{{ overview.n_columns }}</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">Columns</div>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8 space-y-8">

    {# ── Overview Cards ── #}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Dataset Overview
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        <div class="card bg-white rounded-xl border border-gray-100 p-5 border-l-4 border-l-brand-teal">
          <div class="text-xs text-gray-400 uppercase tracking-wider font-medium">Missing Cells</div>
          <div class="text-2xl font-bold text-brand-teal mt-2">{{ overview.missing_cells_pct | format_pct }}</div>
          <div class="text-xs text-gray-400 mt-1">{{ overview.missing_cells | format_number }} cells</div>
        </div>
        <div class="card bg-white rounded-xl border border-gray-100 p-5 border-l-4 border-l-brand-coral">
          <div class="text-xs text-gray-400 uppercase tracking-wider font-medium">Duplicate Rows</div>
          <div class="text-2xl font-bold text-brand-teal mt-2">{{ overview.duplicate_rows | format_number }}</div>
          <div class="text-xs text-gray-400 mt-1">{{ overview.duplicate_rows_pct | format_pct }}</div>
        </div>
        <div class="card bg-white rounded-xl border border-gray-100 p-5 border-l-4 border-l-brand-purple">
          <div class="text-xs text-gray-400 uppercase tracking-wider font-medium">Memory</div>
          <div class="text-2xl font-bold text-brand-teal mt-2">{{ overview.memory_human }}</div>
        </div>
        <div class="card bg-white rounded-xl border border-gray-100 p-5 border-l-4 border-l-brand-peach col-span-2 md:col-span-1 lg:col-span-2">
          <div class="text-xs text-gray-400 uppercase tracking-wider font-medium mb-2">Column Types</div>
          <div class="flex flex-wrap gap-2">
            {% for type_name, count in overview.type_distribution.items() %}
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium
              {% if type_name == 'NUMERIC' %}bg-blue-50 text-blue-700
              {% elif type_name == 'CATEGORICAL' %}bg-emerald-50 text-emerald-700
              {% elif type_name == 'BOOLEAN' %}bg-purple-50 text-purple-700
              {% elif type_name == 'DATETIME' %}bg-amber-50 text-amber-700
              {% elif type_name == 'TEXT' %}bg-rose-50 text-rose-700
              {% else %}bg-gray-50 text-gray-600{% endif %}">
              {{ type_name }}
              <span class="font-bold">{{ count }}</span>
            </span>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {# ── Alerts ── #}
    {% if alerts %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-brand-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Alerts
        <span class="ml-1 inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold bg-brand-coral text-white">
          {{ alerts | length }}
        </span>
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
              <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Scope</th>
              <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Alert</th>
              <th class="text-left px-5 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Value</th>
            </tr>
          </thead>
          <tbody>
            {% for alert in alerts %}
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3">
                {% if alert.column %}
                <span class="font-mono text-sm text-brand-teal font-medium">{{ alert.column }}</span>
                {% if alert.details and alert.details.column_b %}
                <span class="text-gray-400 mx-1">↔</span>
                <span class="font-mono text-sm text-brand-teal font-medium">{{ alert.details.column_b }}</span>
                {% endif %}
                {% else %}
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-gray-100 text-gray-500 italic">dataset</span>
                {% endif %}
              </td>
              <td class="px-5 py-3">
                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold
                  {% if alert.alert_type in ('HIGH_MISSING', 'DUPLICATES') %}bg-red-50 text-red-600 ring-1 ring-red-200
                  {% elif alert.alert_type in ('SKEWED', 'HIGH_ZEROS') %}bg-amber-50 text-amber-600 ring-1 ring-amber-200
                  {% elif alert.alert_type in ('IMBALANCED', 'CONSTANT') %}bg-purple-50 text-purple-600 ring-1 ring-purple-200
                  {% elif alert.alert_type == 'HIGH_CORRELATION' %}bg-blue-50 text-blue-600 ring-1 ring-blue-200
                  {% elif alert.alert_type == 'UNIFORM' %}bg-teal-50 text-teal-600 ring-1 ring-teal-200
                  {% else %}bg-orange-50 text-orange-600 ring-1 ring-orange-200{% endif %}">
                  {{ alert.alert_type }}
                </span>
              </td>
              <td class="px-5 py-3 text-gray-600 font-medium">{{ alert.value | format_pct }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
    {% endif %}

    {# ── Column Details ── #}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Column Details
      </h2>

      {# Pill tabs #}
      <div class="flex flex-wrap gap-2 mb-5" id="col-tabs">
        {% for col_name, col_data in columns.items() %}
        <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium border border-gray-200 bg-white text-gray-600 hover:border-brand-teal hover:text-brand-teal{% if loop.first %} active{% endif %}"
                onclick="switchTab({{ loop.index0 }}, this)">
          <span class="mr-1 opacity-60">
            {% if col_data.column_type == 'NUMERIC' %}#
            {% elif col_data.column_type == 'CATEGORICAL' %}Aa
            {% elif col_data.column_type == 'BOOLEAN' %}◉
            {% elif col_data.column_type == 'DATETIME' %}⏱
            {% elif col_data.column_type == 'TEXT' %}¶
            {% else %}?{% endif %}
          </span>
          {{ col_name }}
        </button>
        {% endfor %}
      </div>

      {# Tab panels #}
      {% for col_name, col_data in columns.items() %}
      <div class="tab-panel{% if loop.first %} active{% endif %}" id="panel-{{ loop.index0 }}">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
            <h3 class="text-lg font-bold text-brand-teal">{{ col_name }}</h3>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold
              {% if col_data.column_type == 'NUMERIC' %}bg-blue-50 text-blue-600
              {% elif col_data.column_type == 'CATEGORICAL' %}bg-emerald-50 text-emerald-600
              {% elif col_data.column_type == 'BOOLEAN' %}bg-purple-50 text-purple-600
              {% elif col_data.column_type == 'DATETIME' %}bg-amber-50 text-amber-600
              {% elif col_data.column_type == 'TEXT' %}bg-rose-50 text-rose-600
              {% else %}bg-gray-100 text-gray-600{% endif %}">
              {{ col_data.column_type }}
            </span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
            {# Stats table #}
            <div class="p-6">
              <table class="w-full text-sm">
                <tbody>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Count</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.count | format_number }}</td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Missing</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.missing_count | format_number }} <span class="text-gray-400 font-normal">({{ col_data.missing_pct | format_pct }})</span></td></tr>
                  {% if col_data.distinct_count is defined %}
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Distinct</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.distinct_count | format_number }} <span class="text-gray-400 font-normal">({{ col_data.distinct_pct | format_pct }})</span></td></tr>
                  {% endif %}

                  {% if col_data.column_type == "NUMERIC" %}
                  {% set s = "py-2 px-3" %}
                  {% set l = "text-gray-500 rounded-l-lg" %}
                  {% set r = "text-right font-semibold text-brand-teal rounded-r-lg" %}
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Mean</td><td class="{{ s }} {{ r }}">{{ col_data.mean | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Std</td><td class="{{ s }} {{ r }}">{{ col_data.std | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Variance</td><td class="{{ s }} {{ r }}">{{ col_data.variance | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Sum</td><td class="{{ s }} {{ r }}">{{ col_data.sum | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">CV</td><td class="{{ s }} {{ r }}">{{ col_data.cv | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">MAD</td><td class="{{ s }} {{ r }}">{{ col_data.mad | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Min</td><td class="{{ s }} {{ r }}">{{ col_data.min | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">P5</td><td class="{{ s }} {{ r }}">{{ col_data.p5 | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Q25</td><td class="{{ s }} {{ r }}">{{ col_data.q25 | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Median</td><td class="{{ s }} {{ r }}">{{ col_data.median | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Q75</td><td class="{{ s }} {{ r }}">{{ col_data.q75 | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">P95</td><td class="{{ s }} {{ r }}">{{ col_data.p95 | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Max</td><td class="{{ s }} {{ r }}">{{ col_data.max | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Range</td><td class="{{ s }} {{ r }}">{{ col_data.range | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">IQR</td><td class="{{ s }} {{ r }}">{{ col_data.iqr | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Skewness</td><td class="{{ s }} {{ r }}">{{ col_data.skewness | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Kurtosis</td><td class="{{ s }} {{ r }}">{{ col_data.kurtosis | format_float }}</td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Zeros</td><td class="{{ s }} {{ r }}">{{ col_data.zeros_count }} <span class="text-gray-400 font-normal">({{ col_data.zeros_pct | format_pct }})</span></td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Negatives</td><td class="{{ s }} {{ r }}">{{ col_data.negative_count }} <span class="text-gray-400 font-normal">({{ col_data.negative_pct | format_pct }})</span></td></tr>
                  <tr class="stat-row"><td class="{{ s }} {{ l }}">Infinite</td><td class="{{ s }} {{ r }}">{{ col_data.n_infinite }}</td></tr>
                  {% if col_data.monotonic_increase %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Monotonic</td><td class="{{ s }} {{ r }}">Increasing</td></tr>{% endif %}
                  {% if col_data.monotonic_decrease %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Monotonic</td><td class="{{ s }} {{ r }}">Decreasing</td></tr>{% endif %}
                  {% endif %}

                  {% if col_data.column_type == "CATEGORICAL" %}
                  {% set s = "py-2 px-3" %}
                  {% set l = "text-gray-500 rounded-l-lg" %}
                  {% set r = "text-right font-semibold text-brand-teal rounded-r-lg" %}
                  {% if col_data.imbalance is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Imbalance</td><td class="{{ s }} {{ r }}">{{ col_data.imbalance | format_pct }}</td></tr>{% endif %}
                  {% if col_data.length_mean is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Avg Length</td><td class="{{ s }} {{ r }}">{{ col_data.length_mean | format_float }}</td></tr>{% endif %}
                  {% if col_data.length_min is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Min Length</td><td class="{{ s }} {{ r }}">{{ col_data.length_min }}</td></tr>{% endif %}
                  {% if col_data.length_max is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Max Length</td><td class="{{ s }} {{ r }}">{{ col_data.length_max }}</td></tr>{% endif %}
                  {% if col_data.length_median is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Median Length</td><td class="{{ s }} {{ r }}">{{ col_data.length_median | format_float }}</td></tr>{% endif %}
                  {% if col_data.word_count_mean is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Avg Words</td><td class="{{ s }} {{ r }}">{{ col_data.word_count_mean | format_float }}</td></tr>{% endif %}
                  {% if col_data.has_non_ascii %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Non-ASCII</td><td class="{{ s }} {{ r }}">Yes</td></tr>{% endif %}
                  {% if col_data.n_characters is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Total Chars</td><td class="{{ s }} {{ r }}">{{ col_data.n_characters | format_number }}</td></tr>{% endif %}
                  {% if col_data.n_characters_distinct is not none %}<tr class="stat-row"><td class="{{ s }} {{ l }}">Distinct Chars</td><td class="{{ s }} {{ r }}">{{ col_data.n_characters_distinct | format_number }}</td></tr>{% endif %}
                  {% endif %}

                  {% if col_data.column_type == "BOOLEAN" %}
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">True</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.true_count }} <span class="text-gray-400 font-normal">({{ col_data.true_pct | format_pct }})</span></td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">False</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.false_count }} <span class="text-gray-400 font-normal">({{ col_data.false_pct | format_pct }})</span></td></tr>
                  {% endif %}

                  {% if col_data.column_type == "DATETIME" %}
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Min</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.min or "—" }}</td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Max</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.max or "—" }}</td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Range</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.range or "—" }}</td></tr>
                  {% endif %}

                  {% if col_data.column_type == "TEXT" %}
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Avg Length</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.length_mean | format_float }}</td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Min Length</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.length_min }}</td></tr>
                  <tr class="stat-row"><td class="py-2 px-3 text-gray-500 rounded-l-lg">Max Length</td><td class="py-2 px-3 text-right font-semibold text-brand-teal rounded-r-lg">{{ col_data.length_max }}</td></tr>
                  {% endif %}
                </tbody>
              </table>
            </div>

            {# Charts #}
            <div class="p-6 border-l border-gray-100">
              {% if col_data.chart_html %}
              <div>{{ col_data.chart_html | safe }}</div>
              {% endif %}
              {% if col_data.wordcloud_html %}
              <div class="mt-4">{{ col_data.wordcloud_html | safe }}</div>
              {% endif %}
              {% if not col_data.chart_html and not col_data.wordcloud_html %}
              <div class="flex items-center justify-center h-full text-gray-300 text-sm italic">No chart available</div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </section>

    {# ── Correlations ── #}
    {% if correlation_charts %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
        Correlations
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="flex gap-2 px-6 pt-4" id="corr-tabs">
          {% for chart in correlation_charts %}
          <button class="tab-btn px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 bg-white text-gray-600 hover:border-brand-teal hover:text-brand-teal{% if loop.first %} active{% endif %}"
                  onclick="switchCorrTab('{{ chart.div_id }}', this)">{{ chart.name }}</button>
          {% endfor %}
        </div>
        {% for chart in correlation_charts %}
        <div class="corr-panel p-6{% if not loop.first %} hidden{% endif %}" id="panel-{{ chart.div_id }}">
          {{ chart.chart_html | safe }}
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# ── Interactions ── #}
    {% if interactions %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
        Interactions
        {% if interactions.sampled %}
        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-amber-50 text-amber-600 ring-1 ring-amber-200">
          Showing {{ interactions.sample_size | format_number }} of {{ interactions.total_rows | format_number }} rows
        </span>
        {% endif %}
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="flex flex-wrap items-center gap-4 px-6 pt-5 pb-3">
          <div class="flex items-center gap-2">
            <label for="interact-x" class="text-sm font-medium text-gray-500">X</label>
            <select id="interact-x" class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal focus:outline-none">
              {% for col in interactions.numeric_columns %}
              <option value="{{ col }}" data-type="numeric"{% if loop.first %} selected{% endif %}>{{ col }} (#)</option>
              {% endfor %}
              {% for col in interactions.categorical_columns %}
              <option value="{{ col }}" data-type="categorical">{{ col }} (Aa)</option>
              {% endfor %}
            </select>
          </div>
          <div class="flex items-center gap-2">
            <label for="interact-y" class="text-sm font-medium text-gray-500">Y</label>
            <select id="interact-y" class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 focus:border-brand-teal focus:ring-1 focus:ring-brand-teal focus:outline-none">
              {% for col in interactions.numeric_columns %}
              <option value="{{ col }}" data-type="numeric"{% if loop.index0 == 1 %} selected{% elif loop.first and interactions.numeric_columns | length == 1 %} selected{% endif %}>{{ col }} (#)</option>
              {% endfor %}
              {% for col in interactions.categorical_columns %}
              <option value="{{ col }}" data-type="categorical">{{ col }} (Aa)</option>
              {% endfor %}
            </select>
          </div>
          <div id="interact-msg" class="text-sm text-gray-400 italic hidden"></div>
        </div>
        <div id="interact-chart" style="width:100%;height:450px" class="px-6 pb-6"></div>
      </div>
    </section>

    <script>
    (function(){
      var numData = {{ interactions.numeric_data_json | safe }};
      var boxData = {{ interactions.boxplot_stats_json | safe }};
      var selX = document.getElementById('interact-x');
      var selY = document.getElementById('interact-y');
      var chartDom = document.getElementById('interact-chart');
      var msgEl = document.getElementById('interact-msg');
      var chart = null;

      function fmtNum(v) {
        if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(1) + 'M';
        if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(1) + 'K';
        return Number.isInteger(v) ? v.toString() : v.toFixed(2);
      }
      function fmtAxis(v) {
        if (Math.abs(v) >= 1e6) return (v/1e6).toFixed(0) + 'M';
        if (Math.abs(v) >= 1e3) return (v/1e3).toFixed(0) + 'K';
        return v;
      }

      var numCols = {{ interactions.numeric_columns | tojson }};
      var catCols = {{ interactions.categorical_columns | tojson }};

      function getType(sel) {
        return sel.options[sel.selectedIndex].getAttribute('data-type');
      }

      function buildOptions(cols, type, symbol) {
        return cols.map(function(c) {
          return '<option value="' + c + '" data-type="' + type + '">' + c + ' (' + symbol + ')</option>';
        }).join('');
      }

      function updateYOptions() {
        var xCol = selX.value;
        var xType = getType(selX);
        var prev = selY.value;
        var avail = numCols.filter(function(c) { return c !== xCol; });
        var html = buildOptions(avail, 'numeric', '#');
        if (xType === 'numeric') {
          html += buildOptions(catCols, 'categorical', 'Aa');
        }
        selY.innerHTML = html;
        var found = false;
        for (var i = 0; i < selY.options.length; i++) {
          if (selY.options[i].value === prev) { selY.selectedIndex = i; found = true; break; }
        }
        if (!found && selY.options.length > 0) selY.selectedIndex = 0;
      }

      function renderInteraction() {
        var xCol = selX.value, yCol = selY.value;
        var xType = getType(selX), yType = getType(selY);

        msgEl.classList.add('hidden');
        msgEl.textContent = '';

        if (xCol === yCol) {
          msgEl.textContent = 'Select two different columns.';
          msgEl.classList.remove('hidden');
          if (chart) { chart.clear(); }
          return;
        }

        if (!chart) { chart = echarts.init(chartDom); }

        if (xType === 'numeric' && yType === 'numeric') {
          renderScatter(xCol, yCol);
        } else {
          var catCol = xType === 'categorical' ? xCol : yCol;
          var numCol = xType === 'categorical' ? yCol : xCol;
          var flipped = (yType === 'categorical');
          renderBoxPlot(catCol, numCol, flipped);
        }
      }

      function renderScatter(xCol, yCol) {
        var xVals = numData[xCol], yVals = numData[yCol];
        var len = Math.min(xVals.length, yVals.length);
        var data = new Array(len);
        for (var i = 0; i < len; i++) { data[i] = [xVals[i], yVals[i]]; }

        var sz = len > 50000 ? 3 : len > 10000 ? 4 : len > 1000 ? 5 : 6;
        var op = len > 50000 ? 0.6 : len > 10000 ? 0.5 : len > 1000 ? 0.6 : 0.8;

        var isLarge = len > 2000;
        chart.setOption({
          animation: false,
          hoverLayerThreshold: 1000,
          title: {text: xCol + '  vs  ' + yCol, left: 'center', textStyle: {fontSize: 13}},
          tooltip: isLarge ? {show: false} : {trigger: 'item', formatter: function(p) {
            return xCol + ': ' + fmtNum(p.data[0]) + '<br>' + yCol + ': ' + fmtNum(p.data[1]);
          }},
          toolbox: {feature: {dataZoom: {title: {zoom: 'Zoom', back: 'Reset'}}, restore: {title: 'Reset'}}},
          grid: {left: '12%', right: '5%', bottom: '12%', top: '12%'},
          xAxis: {type: 'value', name: xCol, nameLocation: 'center', nameGap: 30, nameTextStyle: {fontSize: 12, fontWeight: 'bold'}, axisLabel: {formatter: fmtAxis}},
          yAxis: {type: 'value', name: yCol, nameLocation: 'center', nameGap: 50, nameTextStyle: {fontSize: 12, fontWeight: 'bold'}, axisLabel: {formatter: fmtAxis}},
          dataZoom: [
            {type: 'inside', xAxisIndex: 0, zoomOnMouseWheel: true, moveOnMouseMove: false, moveOnMouseWheel: false},
            {type: 'inside', yAxisIndex: 0, zoomOnMouseWheel: true, moveOnMouseMove: false, moveOnMouseWheel: false}
          ],
          series: [{
            type: 'scatter',
            data: data,
            large: true,
            largeThreshold: 50000,
            progressive: isLarge ? 5000 : 0,
            progressiveThreshold: 10000,
            symbol: 'circle',
            symbolSize: sz,
            itemStyle: {color: 'rgba(232,132,92,' + op + ')'},
            emphasis: {disabled: isLarge}
          }]
        }, true);

        chart.off('restore');
        chart.on('restore', function() {
          chart.setOption({series: [{symbolSize: sz, itemStyle: {color: 'rgba(232,132,92,' + op + ')'}}]});
        });

        var zoomTimer = null;
        chart.off('datazoom');
        chart.on('datazoom', function() {
          if (zoomTimer) clearTimeout(zoomTimer);
          zoomTimer = setTimeout(function() {
            var dz = chart.getOption().dataZoom;
            var xSpan = (dz[0].end - dz[0].start) / 100;
            var ySpan = (dz[1].end - dz[1].start) / 100;
            var zoom = 1 / Math.max(Math.min(xSpan, ySpan), 0.01);
            var newSz = Math.min(Math.max(sz * Math.sqrt(zoom), sz), 14);
            var newOp = Math.min(op + 0.08 * Math.sqrt(zoom), 0.9);
            chart.setOption({series: [{symbolSize: newSz, itemStyle: {color: 'rgba(232,132,92,' + newOp + ')'}}]});
          }, 150);
        });
      }

      function renderBoxPlot(catCol, numCol, flipped) {
        var groups = boxData[catCol] && boxData[catCol][numCol];
        if (!groups || groups.length === 0) {
          msgEl.textContent = 'No box plot data for this pair.';
          msgEl.classList.remove('hidden');
          chart.clear();
          return;
        }

        var categories = [], boxItems = [], outlierPts = [];
        for (var i = 0; i < groups.length; i++) {
          var g = groups[i];
          categories.push(g.category);
          boxItems.push([g.min, g.q1, g.median, g.q3, g.max]);
          for (var j = 0; j < g.outliers.length; j++) {
            outlierPts.push(flipped ? [g.outliers[j], i] : [i, g.outliers[j]]);
          }
        }

        var catAxis = {type: 'category', data: categories, axisLabel: {fontSize: 11}};
        var valAxis = {type: 'value', name: numCol, nameLocation: 'center', nameGap: 45, nameTextStyle: {fontSize: 12, fontWeight: 'bold'}};

        var option = {
          title: {text: catCol + '  vs  ' + numCol, left: 'center', textStyle: {fontSize: 13}},
          tooltip: {trigger: 'item'},
          grid: {left: '12%', right: '5%', bottom: '12%', top: '12%'},
          xAxis: flipped ? valAxis : catAxis,
          yAxis: flipped ? catAxis : valAxis,
          series: [
            {
              type: 'boxplot',
              data: boxItems,
              itemStyle: {color: '#e8f4f2', borderColor: '#0d3b3b'},
              emphasis: {itemStyle: {borderColor: '#e8845c'}}
            },
            {
              type: 'scatter',
              data: outlierPts,
              symbolSize: 5,
              itemStyle: {color: '#e8845c', opacity: 0.7}
            }
          ]
        };
        chart.setOption(option, true);
      }

      selX.addEventListener('change', function() { updateYOptions(); renderInteraction(); });
      selY.addEventListener('change', renderInteraction);

      updateYOptions();
      renderInteraction();

      window.addEventListener('resize', function() {
        if (chart) chart.resize();
      });
    })();
    </script>
    {% endif %}

    {# ── Missing Values ── #}
    {% if missing_bar_chart %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Missing Values
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
        <div>{{ missing_bar_chart | safe }}</div>
        {% if overview.missing_per_column %}
        <div class="mt-6 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                <th class="text-left px-4 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider">Column</th>
                <th class="text-right px-4 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider">Missing</th>
                <th class="text-right px-4 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider">%</th>
              </tr>
            </thead>
            <tbody>
              {% for col_name, info in overview.missing_per_column.items() if info.count > 0 %}
              <tr class="stat-row border-b border-gray-50">
                <td class="px-4 py-2 font-mono text-sm text-brand-teal font-medium">{{ col_name }}</td>
                <td class="px-4 py-2 text-right font-semibold">{{ info.count | format_number }}</td>
                <td class="px-4 py-2 text-right text-gray-500">{{ info.pct | format_pct }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}
      </div>
    </section>
    {% endif %}

    {# ── Sample ── #}
    {% if overview.sample_head %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Sample
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="flex gap-2 px-6 pt-4">
          <button class="tab-btn active px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 bg-white text-gray-600" onclick="switchSampleTab('head', this)">Head</button>
          <button class="tab-btn px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 bg-white text-gray-600" onclick="switchSampleTab('tail', this)">Tail</button>
        </div>
        <div id="sample-head" class="p-6 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                {% for col_name in overview.sample_head[0].keys() %}
                <th class="text-left px-3 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider whitespace-nowrap">{{ col_name }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in overview.sample_head %}
              <tr class="stat-row border-b border-gray-50">
                {% for val in row.values() %}
                <td class="px-3 py-2 whitespace-nowrap max-w-xs truncate" title="{{ val }}">{{ val if val is not none else "null" }}</td>
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div id="sample-tail" class="p-6 overflow-x-auto" style="display:none">
          {% if overview.sample_tail %}
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                {% for col_name in overview.sample_tail[0].keys() %}
                <th class="text-left px-3 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider whitespace-nowrap">{{ col_name }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in overview.sample_tail %}
              <tr class="stat-row border-b border-gray-50">
                {% for val in row.values() %}
                <td class="px-3 py-2 whitespace-nowrap max-w-xs truncate" title="{{ val }}">{{ val if val is not none else "null" }}</td>
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
          {% endif %}
        </div>
      </div>
    </section>
    {% endif %}

    {# ── Duplicate Rows ── #}
    {% if overview.duplicate_rows_sample %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Duplicate Rows
        <span class="ml-1 inline-flex items-center justify-center px-2 py-0.5 rounded-full text-xs font-bold bg-brand-coral text-white">
          {{ overview.duplicate_rows | format_number }}
        </span>
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
              {% for col_name in overview.duplicate_rows_sample[0].keys() %}
              <th class="text-left px-3 py-2 font-semibold text-gray-500 text-xs uppercase tracking-wider whitespace-nowrap">{{ col_name }}</th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in overview.duplicate_rows_sample %}
            <tr class="stat-row border-b border-gray-50">
              {% for val in row.values() %}
              <td class="px-3 py-2 whitespace-nowrap max-w-xs truncate" title="{{ val }}">{{ val if val is not none else "null" }}</td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
    {% endif %}

    {# ── Reproduction ── #}
    {% if overview.reproduction %}
    <section>
      <h2 class="text-lg font-semibold text-brand-teal mb-4 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Reproduction Details
      </h2>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
        <table class="text-sm">
          <tbody>
            {% for key, val in overview.reproduction.items() %}
            <tr class="stat-row">
              <td class="py-2 px-4 text-gray-500 font-medium">{{ key }}</td>
              <td class="py-2 px-4 font-mono text-brand-teal">{{ val }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
    {% endif %}

  </main>

  {# ── Footer ── #}
  <footer class="mt-12 border-t-2 border-brand-teal/10">
    <div class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
      <div class="flex items-center gap-3">
        {% if icon_b64 %}
        <img src="data:image/png;base64,{{ icon_b64 }}" alt="DataXID" class="h-6 w-6" />
        {% endif %}
        <span class="text-sm text-gray-400">
          Powered by
          <a href="https://github.com/dataxid/dataxid-profiling" class="font-semibold text-brand-teal hover:text-brand-coral transition-colors">dataxid-profiling</a>
        </span>
      </div>
      <span class="text-xs text-gray-300">Polars-native data profiling</span>
    </div>
  </footer>

  {# ── Tab switching JS ── #}
  <script>
    function switchTab(idx, btn) {
      document.querySelectorAll('#col-tabs .tab-btn').forEach(b => { b.classList.remove('active'); });
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      var panel = document.getElementById('panel-' + idx);
      if (panel) panel.classList.add('active');
      panel.querySelectorAll('[id^="col_chart_"],[id^="col_wc_"]').forEach(function(el) {
        var chart = echarts.getInstanceByDom(el);
        if (chart) chart.resize();
      });
    }
    function switchCorrTab(divId, btn) {
      document.querySelectorAll('#corr-tabs .tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.corr-panel').forEach(p => p.classList.add('hidden'));
      btn.classList.add('active');
      var panel = document.getElementById('panel-' + divId);
      if (panel) {
        panel.classList.remove('hidden');
        var el = document.getElementById(divId);
        if (el) { var c = echarts.getInstanceByDom(el); if (c) c.resize(); }
      }
    }
    function switchSampleTab(which, btn) {
      btn.parentElement.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('sample-head').style.display = which === 'head' ? 'block' : 'none';
      document.getElementById('sample-tail').style.display = which === 'tail' ? 'block' : 'none';
    }
  </script>

</body>
</html>
